# SureRide — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# PesaPal payment gateway — https://developer.pesapal.com
# Leave blank to run in demo/mock mode
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=sandbox
PESAPAL_IPN_URL=https://sureride.co.ke/ipn
